  "collection_id": null,
  "environment_id": null,
  "collection": {
    "info": {
      "name": "FarmApp API",
      "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
      "description": "FarmApp — Poultry Farm Management System. Base URL: http://localhost/farmapp. Auth: session cookie via POST /login/submit."
